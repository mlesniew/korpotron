# Copy to .env for local dev. Never commit .env.
SECRET_KEY=change-me-generate-with-python-secrets
DEBUG=True
# ALLOWED_HOSTS is used locally; on Fly.io the app domain comes from FLY_APP_NAME automatically.
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=
# OpenRouter (LLM provider) — required for the text-generation flow to work.
# The app boots without it, but Generate fails until it is set. See ADR 001.
OPENROUTER_API_KEY=
# Optional — sensible defaults are used if unset.
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# DAILY_GENERATION_LIMIT=100  # set to 0 for unlimited
